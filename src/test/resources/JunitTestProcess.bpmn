  <signal id="testSignal0" name="testSignal0" activiti:scope="global"></signal>
  <signal id="testSignal1" name="testSignal1" activiti:scope="global"></signal>
  <signal id="testSignal2" name="testSignal2" activiti:scope="global"></signal>
  <process id="JUNIT-TEST" name="Junit-Test-Process" isExecutable="true">
    <startEvent id="startEvent" name="Start" activiti:initiator="initiator"></startEvent>
    <sequenceFlow id="flowToTaskCopyRefFilesToSoll" sourceRef="startEvent" targetRef="UserTask0"></sequenceFlow>
    <userTask id="UserTask0" name="UserTask #0">
      <extensionElements>
        <activiti:formProperty id="signalType" name="Signal Type" type="enum" variable="signalType" required="true">
          <activiti:value id="signalType0" name="Signal Type 0"></activiti:value>
          <activiti:value id="signalType1" name="Signal Type 1"></activiti:value>
          <activiti:value id="signalType2" name="Signal Type 2"></activiti:value>
        </activiti:formProperty>
      </extensionElements>
    </userTask>
    <intermediateThrowEvent id="SignalIntermediateThrowEvent1" name="SignalThrowEvent #1">
      <signalEventDefinition signalRef="testSignal0"></signalEventDefinition>
    </intermediateThrowEvent>
    <sequenceFlow id="flow2" sourceRef="UserTask0" targetRef="exclusivegateway1"></sequenceFlow>
    <exclusiveGateway id="exclusivegateway1" name="Exclusive Gateway"></exclusiveGateway>
    <sequenceFlow id="flow4" sourceRef="exclusivegateway1" targetRef="SignalIntermediateThrowEvent1">
      <conditionExpression xsi:type="tFormalExpression"><![CDATA[${signalType == "signalType0"}]]></conditionExpression>
    </sequenceFlow>
    <intermediateThrowEvent id="SignalIntermediateThrowEvent2" name="SignalThrowEvent #2">
      <signalEventDefinition signalRef="testSignal1"></signalEventDefinition>
    </intermediateThrowEvent>
    <intermediateThrowEvent id="SignalIntermediateThrowEvent3" name="SignalThrowEvent #3">
      <signalEventDefinition signalRef="testSignal2"></signalEventDefinition>
    </intermediateThrowEvent>
    <sequenceFlow id="flow5" sourceRef="exclusivegateway1" targetRef="SignalIntermediateThrowEvent3">
      <conditionExpression xsi:type="tFormalExpression"><![CDATA[${signalType == "signalType2"}]]></conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow6" sourceRef="exclusivegateway1" targetRef="SignalIntermediateThrowEvent2">
      <conditionExpression xsi:type="tFormalExpression"><![CDATA[${signalType == "signalType1"}]]></conditionExpression>
    </sequenceFlow>
    <endEvent id="endevent1" name="End"></endEvent>
    <sequenceFlow id="flow7" sourceRef="SignalIntermediateThrowEvent3" targetRef="UserTask2.0"></sequenceFlow>
    <sequenceFlow id="flow8" sourceRef="SignalIntermediateThrowEvent2" targetRef="UserTask1.0"></sequenceFlow>
    <sequenceFlow id="flow9" sourceRef="SignalIntermediateThrowEvent1" targetRef="UserTask0.0"></sequenceFlow>
    <serviceTask id="mailtask1" name="Mail Task" activiti:type="mail">
      <extensionElements>
        <activiti:field name="to">
          <activiti:string><![CDATA[k.cavdar@activiti-tester.de]]></activiti:string>
        </activiti:field>
        <activiti:field name="from">
          <activiti:string><![CDATA[junit@activiti-tester.de]]></activiti:string>
        </activiti:field>
        <activiti:field name="subject">
          <activiti:string><![CDATA[JUNITTest]]></activiti:string>
        </activiti:field>
        <activiti:field name="text">
          <activiti:expression><![CDATA[Mail from Signal ${signalType}]]></activiti:expression>
        </activiti:field>
      </extensionElements>
    </serviceTask>
    <sequenceFlow id="flow10" sourceRef="mailtask1" targetRef="endevent1"></sequenceFlow>
